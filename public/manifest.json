{
  "manifest_version": 3,
  "name": "SARA AI Assistant",
  "version": "2.2",
  "description": "SARA - Your AI Assistant that controls the web",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "clipboardRead",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open SARA"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
